#!/usr/bin/env bash
# quietshrink — compress screen recordings with zero CPU stress
# Pareto-optimal balance: max quality, min size, silent computer, fast.
# Apple Silicon optimized (uses hardware HEVC encoder + smart frame deduplication).

set -euo pipefail

VERSION="1.0.0"

# Default settings (transparent quality preset)
QUALITY="${QUIETSHRINK_QUALITY:-transparent}"
GOP="${QUIETSHRINK_GOP:-600}"
AUDIO_BITRATE="${QUIETSHRINK_AUDIO_BITRATE:-96k}"
JSON_OUTPUT="${QUIETSHRINK_JSON:-false}"
VERBOSE="${QUIETSHRINK_VERBOSE:-false}"

# Quality presets → q value (no associative array — bash 3.2 compat)
PRESET_NAMES="tiny balanced transparent pristine"
preset_q() {
  case "$1" in
    tiny)        echo 50 ;;  # ~90% reduction, SSIM ~0.95 (good but not transparent)
    balanced)    echo 55 ;;  # ~88% reduction, SSIM ~0.99 (very high quality)
    transparent) echo 60 ;;  # ~87% reduction, SSIM ~0.99+ (visually lossless)
    pristine)    echo 70 ;;  # ~84% reduction, SSIM ~0.997 (near-source)
    *)           echo "" ;;
  esac
}

# Color output (only if terminal)
if [ -t 1 ]; then
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_DIM=$'\033[2m'
  C_GREEN=$'\033[32m'
  C_BLUE=$'\033[34m'
  C_YELLOW=$'\033[33m'
  C_RED=$'\033[31m'
  C_CYAN=$'\033[36m'
else
  C_RESET=""; C_BOLD=""; C_DIM=""; C_GREEN=""
  C_BLUE=""; C_YELLOW=""; C_RED=""; C_CYAN=""
fi

usage() {
  cat <<EOF
${C_BOLD}quietshrink${C_RESET} — compress screen recordings without making your fans spin

${C_BOLD}USAGE${C_RESET}
  quietshrink <input> [output]
  quietshrink [options] <input> [output]

${C_BOLD}OPTIONS${C_RESET}
  -q, --quality <preset>   Quality preset: tiny, balanced, transparent (default), pristine
  -g, --gop <n>            GOP size (default: 600). Larger = smaller files for static content.
  -a, --audio <bitrate>    Audio bitrate (default: 96k)
  --replace                Replace input file with compressed version
  --json                   JSON output (for scripts/agents)
  -v, --verbose            Show ffmpeg progress
  -h, --help               Show this help
  -V, --version            Show version

${C_BOLD}EXAMPLES${C_RESET}
  ${C_DIM}# Default: transparent quality (visually lossless)${C_RESET}
  quietshrink recording.mov

  ${C_DIM}# Tiny preset for chat sharing${C_RESET}
  quietshrink -q tiny recording.mov small.mov

  ${C_DIM}# Replace original after compression${C_RESET}
  quietshrink --replace recording.mov

  ${C_DIM}# Batch a folder${C_RESET}
  for f in ~/Desktop/*.mov; do quietshrink "\$f"; done

${C_BOLD}HOW IT WORKS${C_RESET}
  • ${C_CYAN}hevc_videotoolbox${C_RESET}: Apple Silicon's hardware encoder (zero CPU stress)
  • ${C_CYAN}mpdecimate${C_RESET}: Removes duplicate frames common in screen recordings
  • ${C_CYAN}spatial_aq${C_RESET}: Allocates more bits to text/edges, fewer to flat areas
  • ${C_CYAN}long GOP${C_RESET}: Reduces redundant keyframes for static content

  Result: typically 70-90% smaller files at visually identical quality,
  encoded at 2x realtime speed with the computer staying silent.

${C_BOLD}REQUIREMENTS${C_RESET}
  • macOS with Apple Silicon (M1/M2/M3/M4)
  • ffmpeg 6+ (\`brew install ffmpeg\`)

EOF
}

log() { [ "$JSON_OUTPUT" = "true" ] || echo "$@" >&2; }

# Format bytes to human readable
hr_bytes() {
  local bytes=$1
  if [ "$bytes" -ge 1073741824 ]; then
    awk -v b="$bytes" 'BEGIN { printf "%.2f GB", b/1073741824 }'
  elif [ "$bytes" -ge 1048576 ]; then
    awk -v b="$bytes" 'BEGIN { printf "%.2f MB", b/1048576 }'
  elif [ "$bytes" -ge 1024 ]; then
    awk -v b="$bytes" 'BEGIN { printf "%.2f KB", b/1024 }'
  else
    echo "$bytes B"
  fi
}

# Check requirements
check_requirements() {
  if ! command -v ffmpeg >/dev/null 2>&1; then
    log "${C_RED}✗${C_RESET} ffmpeg not found. Install with: ${C_CYAN}brew install ffmpeg${C_RESET}"
    exit 2
  fi
  if [ "$(uname -s)" != "Darwin" ]; then
    log "${C_YELLOW}⚠${C_RESET} quietshrink is optimized for macOS. Other platforms work but without hardware acceleration."
  fi
  if ! ffmpeg -hide_banner -encoders 2>&1 | grep -q "hevc_videotoolbox"; then
    log "${C_RED}✗${C_RESET} Your ffmpeg lacks hevc_videotoolbox. Reinstall: ${C_CYAN}brew reinstall ffmpeg${C_RESET}"
    exit 2
  fi
}

# Parse arguments
INPUT=""
OUTPUT=""
REPLACE=false

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -V|--version) echo "quietshrink $VERSION"; exit 0 ;;
    -q|--quality) QUALITY="$2"; shift 2 ;;
    -g|--gop) GOP="$2"; shift 2 ;;
    -a|--audio) AUDIO_BITRATE="$2"; shift 2 ;;
    --replace) REPLACE=true; shift ;;
    --json) JSON_OUTPUT=true; shift ;;
    -v|--verbose) VERBOSE=true; shift ;;
    -*) log "${C_RED}✗${C_RESET} Unknown option: $1"; usage; exit 1 ;;
    *)
      if [ -z "$INPUT" ]; then INPUT="$1"
      elif [ -z "$OUTPUT" ]; then OUTPUT="$1"
      else log "${C_RED}✗${C_RESET} Too many arguments"; exit 1; fi
      shift
      ;;
  esac
done

[ -z "$INPUT" ] && { usage; exit 1; }
[ -f "$INPUT" ] || { log "${C_RED}✗${C_RESET} File not found: $INPUT"; exit 1; }

check_requirements

# Validate quality preset
Q_VALUE=$(preset_q "$QUALITY")
if [ -z "$Q_VALUE" ]; then
  log "${C_RED}✗${C_RESET} Unknown quality preset: $QUALITY"
  log "  Available: $PRESET_NAMES"
  exit 1
fi

# Auto-derive output filename
if [ -z "$OUTPUT" ]; then
  if [ "$REPLACE" = true ]; then
    OUTPUT="${INPUT%.mov}.quietshrink.mov"
  else
    OUTPUT="${INPUT%.*}_compressed.${INPUT##*.}"
  fi
fi

# Ensure output ends in .mov or .mp4
case "$OUTPUT" in
  *.mov|*.mp4) ;;
  *) OUTPUT="${OUTPUT}.mov" ;;
esac

# Get input stats
INPUT_SIZE=$(stat -f%z "$INPUT" 2>/dev/null || stat -c%s "$INPUT")
DURATION=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$INPUT" 2>/dev/null | awk '{printf "%.1f", $1}')

# Banner
if [ "$JSON_OUTPUT" != "true" ]; then
  echo
  log "${C_BOLD}quietshrink${C_RESET} ${C_DIM}v${VERSION}${C_RESET}"
  log "  ${C_DIM}input:${C_RESET}    $INPUT ${C_DIM}($(hr_bytes "$INPUT_SIZE"), ${DURATION}s)${C_RESET}"
  log "  ${C_DIM}output:${C_RESET}   $OUTPUT"
  log "  ${C_DIM}quality:${C_RESET}  $QUALITY ${C_DIM}(q=$Q_VALUE)${C_RESET}"
  log "  ${C_DIM}gop:${C_RESET}      $GOP"
  log
  log "  ${C_BLUE}●${C_RESET} encoding..."
fi

# Build the ffmpeg command
LOG_LEVEL="error"
[ "$VERBOSE" = true ] && LOG_LEVEL="info"

# Run ffmpeg
START_TIME=$(date +%s)

# mpdecimate drops duplicate frames (common in screen recordings).
# We keep the ORIGINAL timestamps of the surviving frames via -fps_mode vfr,
# so a static frame is simply held for the duration it was actually on screen.
# (The old "setpts=N/FRAME_RATE/TB" re-stamped frames by index at the nominal
#  r_frame_rate — e.g. 120fps — which crushed the video into a fraction of its
#  real length: footage played ~ realtime×fps/avg too fast and the last frame
#  froze for the rest of the audio. Screen recordings are VFR, so never do that.)
ffmpeg -i "$INPUT" \
  -vf "mpdecimate" \
  -fps_mode:v vfr \
  -c:v hevc_videotoolbox -q:v "$Q_VALUE" \
  -prio_speed 0 -spatial_aq 1 \
  -g "$GOP" \
  -tag:v hvc1 \
  -c:a aac -b:a "$AUDIO_BITRATE" \
  -movflags +faststart \
  -hide_banner -loglevel "$LOG_LEVEL" \
  "$OUTPUT" -y 2>&1 | (if [ "$VERBOSE" != true ]; then cat >&2; else cat; fi)

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

# Get output stats
OUTPUT_SIZE=$(stat -f%z "$OUTPUT" 2>/dev/null || stat -c%s "$OUTPUT")
SAVED_BYTES=$((INPUT_SIZE - OUTPUT_SIZE))
SAVED_PERCENT=$(awk -v s="$SAVED_BYTES" -v i="$INPUT_SIZE" 'BEGIN { printf "%.1f", (s/i)*100 }')
SPEED=$(awk -v d="$DURATION" -v e="$ELAPSED" 'BEGIN { if (e>0) printf "%.1fx", d/e; else print "∞" }')

# Replace original if requested
if [ "$REPLACE" = true ]; then
  TEMP="${INPUT}.quietshrink_backup"
  mv "$INPUT" "$TEMP"
  mv "$OUTPUT" "$INPUT"
  rm "$TEMP"
  OUTPUT="$INPUT"
fi

# Output result
if [ "$JSON_OUTPUT" = "true" ]; then
  cat <<EOF
{
  "input": "$INPUT",
  "output": "$OUTPUT",
  "input_size": $INPUT_SIZE,
  "output_size": $OUTPUT_SIZE,
  "saved_bytes": $SAVED_BYTES,
  "saved_percent": $SAVED_PERCENT,
  "duration_seconds": $DURATION,
  "elapsed_seconds": $ELAPSED,
  "encoding_speed": "$SPEED",
  "quality_preset": "$QUALITY",
  "q_value": $Q_VALUE,
  "gop": $GOP
}
EOF
else
  echo
  log "  ${C_GREEN}✓${C_RESET} done in ${ELAPSED}s ${C_DIM}(${SPEED} realtime)${C_RESET}"
  log
  log "  ${C_BOLD}before:${C_RESET}  $(hr_bytes "$INPUT_SIZE")"
  log "  ${C_BOLD}after:${C_RESET}   $(hr_bytes "$OUTPUT_SIZE")"
  log "  ${C_BOLD}saved:${C_RESET}   ${C_GREEN}$(hr_bytes "$SAVED_BYTES") (${SAVED_PERCENT}%)${C_RESET}"
  log
fi
